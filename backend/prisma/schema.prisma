generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Match {
  id        Int      @id @default(autoincrement())
  home_team String
  away_team String
  reports   Report[]
}

model Report {
  id         Int    @id @default(autoincrement())
  match_id   Int
  home_score Int
  away_score Int
  sub        String
  match      Match  @relation(fields: [match_id], references: [id], onDelete: Cascade)
}
